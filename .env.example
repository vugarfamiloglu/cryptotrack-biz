# CryptoTrack Biz — environment. Copy to .env. Sane local defaults are baked in.

PORT=6800

# Session signing secret (HS256). Generate for production: openssl rand -hex 32
SESSION_SECRET=

# AES-256-GCM vault master key (hex, 32 bytes). Generated to data/.vault-key if unset.
VAULT_KEY=

# Price provider: coingecko (keyless default). Poll interval in seconds (floor 30).
PRICE_PROVIDER=coingecko
PRICE_POLL_SECONDS=60
COINGECKO_API_KEY=

# FX provider (keyless): open.er-api.com
FX_BASE=USD

# Seed admin (used only when seeding an empty DB)
SEED_ADMIN_EMAIL=cfo@acme.test
SEED_ADMIN_PASSWORD=Treasury2026!
